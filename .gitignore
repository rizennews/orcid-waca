# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ─────────────────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── AI Agent Workspace ───────────────────────────────────────────────────────
.agents/
skills-lock.json
AGENTS.md
CLAUDE.md

# ─── Testing ─────────────────────────────────────────────────────────────────
/coverage

# ─── Environment Variables ───────────────────────────────────────────────────
# Keep .env.example, ignore everything else
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.production

# ─── Debug Logs ──────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ─── OS Files ────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Editor / IDE ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── TypeScript ──────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Deployment ──────────────────────────────────────────────────────────────
.vercel
.netlify

# ─── Security ────────────────────────────────────────────────────────────────
*.pem
*.key
*.cert
